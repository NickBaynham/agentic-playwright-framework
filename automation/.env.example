# Environment overrides for the SauceDemo automation framework.
# Copy this file to .env and fill in values that differ from automation/config/environments.yaml.
# Never commit .env or any file containing real credentials or secrets.

# Active environment selector: local | dev | qa
APP_ENV=local

# Optional overrides
# BASE_URL=https://www.saucedemo.com
# API_URL=
# BROWSER=chromium
# HEADLESS=true

# Secrets (do not commit). Production credentials should never be placed here;
# use a secret manager or per-developer .env files outside source control.
# SAUCEDEMO_PASSWORD=
